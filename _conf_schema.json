{
  "super_admins": {
    "type": "list",
    "description": "超级管理员QQ号列表",
    "hint": "拥有所有权限，可管理网络拓扑和执行所有处罚指令。添加后请重载插件生效",
    "default": [],
    "items": {
      "type": "string"
    }
  },
  "groups": {
    "type": "text",
    "description": "QQ群联动组配置",
    "hint": "填写 JSON 对象。键是联动组名称，值包含 log_group 和 exec_groups。群号可填写纯群号，也可填写完整 UMO，例如 aiocqhttp:GroupMessage:123456789。",
    "default": "{\n  \"主群网络\": {\n    \"log_group\": \"123456789\",\n    \"exec_groups\": [\n      \"123456789\",\n      \"987654321\"\n    ]\n  }\n}",
    "editor_mode": true,
    "editor_language": "json"
  },
  "blacklist": {
    "type": "list",
    "description": "黑名单列表",
    "hint": "被加入黑名单的用户尝试进群时会被自动踢出。也可通过 /kick -b 指令自动添加",
    "default": [],
    "items": {
      "type": "object",
      "items": {
        "qq": {
          "type": "string",
          "description": "QQ号"
        },
        "reason": {
          "type": "string",
          "description": "原因"
        },
        "time": {
          "type": "string",
          "description": "加入黑名单时间"
        },
        "operator": {
          "type": "string",
          "description": "操作者QQ号"
        }
      }
    }
  },
  "ignore_send_timeout_1200": {
    "type": "bool",
    "description": "是否忽略 OneBot 发送消息 retcode=1200 超时",
    "hint": "NapCat/SnowLuma 兼容端偶尔会在消息已发出后仍返回发送超时。开启后，发送群消息出现此类超时时按可能成功处理。",
    "default": true
  }
}
